LOG_LEVEL=
GOOGLE_SERVICE_ACCOUNT=
GOOGLE_DRIVE_EMAILS=

# Stockbit token storage / server mode
# Persistent directory for the Stockbit token files. Defaults to the system temp
# dir; set an explicit path on servers where /tmp is wiped on reboot.
STOCKBIT_TOKEN_DIR=
# Set to 1/true on a headless server (no Chrome). The client then renews tokens
# only via the refresh token and never tries to launch a browser.
STOCKBIT_DISABLE_BROWSER_LOGIN=